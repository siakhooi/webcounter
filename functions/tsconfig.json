{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "nodeNext",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "target": "es2020",
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "ignoreDeprecations": "6.0",
  "compileOnSave": true,
  "include": [
    "src"
  ]
}
